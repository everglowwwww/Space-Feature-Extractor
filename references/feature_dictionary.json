[
  {"field": "case_name",                "中文名": "案例名称",         "单位": "-",      "来源": "用户指定",    "类型": "文本",  "说明": "案例唯一标识"},
  {"field": "space_type",               "中文名": "空间类型",         "单位": "-",      "来源": "LLM",        "类型": "文本",  "说明": "如共享办公-休闲协作区、独立工位区等"},

  {"field": "length_m",                 "中文名": "空间总长度",       "单位": "m",      "来源": "LLM",        "类型": "数值",  "说明": "空间最长方向尺寸"},
  {"field": "width_m",                  "中文名": "空间宽度",         "单位": "m",      "来源": "LLM",        "类型": "数值",  "说明": "空间较短方向尺寸"},
  {"field": "ceiling_height_m",         "中文名": "层高",             "单位": "m",      "来源": "LLM",        "类型": "数值",  "说明": "地面到天花板净高"},
  {"field": "net_area_m2",              "中文名": "净使用面积",       "单位": "m²",     "来源": "LLM",        "类型": "数值",  "说明": "去除墙体后的可用地面面积"},
  {"field": "volume_m3",                "中文名": "空间体积",         "单位": "m³",     "来源": "LLM",        "类型": "数值",  "说明": "净面积 × 层高"},

  {"field": "num_windows",              "中文名": "窗户数量",         "单位": "组",     "来源": "LLM",        "类型": "整数",  "说明": "独立窗组数量"},
  {"field": "window_wall_ratio",        "中文名": "窗墙比",           "单位": "-",      "来源": "LLM",        "类型": "数值",  "说明": "窗面积/围护面总面积, 办公推荐0.30-0.50"},
  {"field": "num_doors",                "中文名": "门/出入口数量",    "单位": "个",     "来源": "LLM",        "类型": "整数",  "说明": "含开放式通道"},
  {"field": "perimeter_m",              "中文名": "围合周长",         "单位": "m",      "来源": "LLM",        "类型": "数值",  "说明": "空间平面轮廓周长"},
  {"field": "enclosure_ratio",          "中文名": "围合度",           "单位": "-",      "来源": "LLM",        "类型": "数值",  "说明": "0=完全开放, 0.5=半开放, 1=完全封闭"},

  {"field": "height_width_ratio",       "中文名": "高宽比",           "单位": "-",      "来源": "LLM",        "类型": "数值",  "说明": "层高/宽度, 0.5-0.7舒适"},
  {"field": "length_width_ratio",       "中文名": "长宽比",           "单位": "-",      "来源": "LLM",        "类型": "数值",  "说明": "1.0=正方, >2.5=狭长"},

  {"field": "total_seats",              "中文名": "总座位数",         "单位": "座",     "来源": "LLM",        "类型": "整数",  "说明": "空间内所有可坐座位总数"},
  {"field": "furniture_density",        "中文名": "家具密度",         "单位": "-",      "来源": "LLM",        "类型": "数值",  "说明": "家具投影面积/净地面积, 0.2宽松, 0.3-0.4适中"},
  {"field": "seating_density_per_m2",   "中文名": "座位密度",         "单位": "座/m²",  "来源": "LLM",        "类型": "数值",  "说明": "座位数/净面积, 人均>3m²宽松, <2m²拥挤"},

  {"field": "color_temperature_K",      "中文名": "色温(LLM判读)",    "单位": "K",      "来源": "LLM",        "类型": "整数",  "说明": "2700K暖白, 4000K中性白, 6500K日光白"},
  {"field": "color_scheme",             "中文名": "色调方案",         "单位": "-",      "来源": "LLM",        "类型": "文本",  "说明": "如暖中性色调、冷灰色调等"},
  {"field": "floor_material",           "中文名": "地面材质",         "单位": "-",      "来源": "LLM",        "类型": "文本",  "说明": "主要地面饰面材质"},
  {"field": "wall_material",            "中文名": "墙面材质",         "单位": "-",      "来源": "LLM",        "类型": "文本",  "说明": "主要墙面饰面材质"},
  {"field": "ceiling_material",         "中文名": "天花材质",         "单位": "-",      "来源": "LLM",        "类型": "文本",  "说明": "主要天花饰面材质"},

  {"field": "color_1_hex",              "中文名": "主色1-色值",       "单位": "-",      "来源": "LLM",        "类型": "文本",  "说明": "面积占比最大的颜色HEX值"},
  {"field": "color_1_ral",              "中文名": "主色1-RAL编号",    "单位": "-",      "来源": "LLM",        "类型": "文本",  "说明": "最近似RAL标准色号"},
  {"field": "color_1_pct",              "中文名": "主色1-面积占比",   "单位": "%",      "来源": "LLM",        "类型": "数值",  "说明": "该色在空间中的视觉面积占比"},
  {"field": "color_2_hex",              "中文名": "主色2-色值",       "单位": "-",      "来源": "LLM",        "类型": "文本",  "说明": "面积占比第二的颜色HEX值"},
  {"field": "color_2_ral",              "中文名": "主色2-RAL编号",    "单位": "-",      "来源": "LLM",        "类型": "文本",  "说明": "最近似RAL标准色号"},
  {"field": "color_2_pct",              "中文名": "主色2-面积占比",   "单位": "%",      "来源": "LLM",        "类型": "数值",  "说明": "该色在空间中的视觉面积占比"},
  {"field": "color_3_hex",              "中文名": "主色3-色值",       "单位": "-",      "来源": "LLM",        "类型": "文本",  "说明": "面积占比第三的颜色HEX值"},
  {"field": "color_3_ral",              "中文名": "主色3-RAL编号",    "单位": "-",      "来源": "LLM",        "类型": "文本",  "说明": "最近似RAL标准色号"},
  {"field": "color_3_pct",              "中文名": "主色3-面积占比",   "单位": "%",      "来源": "LLM",        "类型": "数值",  "说明": "该色在空间中的视觉面积占比"},

  {"field": "lighting_type",            "中文名": "灯具类型",         "单位": "-",      "来源": "LLM",        "类型": "文本",  "说明": "主要灯具形式，如吊灯、筒灯、灯带"},
  {"field": "num_visible_lights",       "中文名": "可见灯具数量",     "单位": "个",     "来源": "LLM",        "类型": "整数",  "说明": "透视照中可数的灯具数"},
  {"field": "estimated_illuminance_lux","中文名": "估算照度",         "单位": "lux",    "来源": "LLM",        "类型": "整数",  "说明": "100走廊, 300休闲, 500办公"},
  {"field": "daylight_factor",          "中文名": "采光系数",         "单位": "-",      "来源": "LLM",        "类型": "数值",  "说明": "0.02最低, 0.035良好, >0.05优秀"},
  {"field": "openness_score",           "中文名": "开阔感评分",       "单位": "-",      "来源": "LLM",        "类型": "数值",  "说明": "0.3封闭, 0.5标准, 0.7开放大厅"},
  {"field": "privacy_score",            "中文名": "私密性评分",       "单位": "-",      "来源": "LLM",        "类型": "数值",  "说明": "0全开放, 0.5有隔断, 1全封闭"},
  {"field": "estimated_RT60_s",         "中文名": "混响时间RT60",     "单位": "s",      "来源": "LLM",        "类型": "数值",  "说明": "0.6-0.8办公推荐, >1.5体育馆级"},

  {"field": "cv_compactness",           "中文名": "平面紧凑度",       "单位": "-",      "来源": "OpenCV",     "类型": "数值",  "说明": "4πA/P², 圆=1, 正方形≈0.785, 越小越不规则"},
  {"field": "cv_rectangularity",        "中文名": "平面矩形度",       "单位": "-",      "来源": "OpenCV",     "类型": "数值",  "说明": "面积/最小外接矩形, 1=完美矩形"},
  {"field": "cv_convexity",             "中文名": "平面凸性",         "单位": "-",      "来源": "OpenCV",     "类型": "数值",  "说明": "面积/凸包面积, 1=完全凸, <0.9有凹角"},
  {"field": "cv_h_transparency",        "中文名": "水平通透度",       "单位": "-",      "来源": "OpenCV",     "类型": "数值",  "说明": "水平方向无遮挡连续比例, 0.7=通透"},
  {"field": "cv_v_transparency",        "中文名": "垂直通透度",       "单位": "-",      "来源": "OpenCV",     "类型": "数值",  "说明": "垂直方向无遮挡连续比例, 0.7=通透"},

  {"field": "sem_shell_pct",            "中文名": "语义-围护壳体占比", "单位": "%",     "来源": "Mask2Former", "类型": "数值",  "说明": "墙面+天花板+柱子在画面中的面积占比"},
  {"field": "sem_floor_pct",            "中文名": "语义-地面占比",     "单位": "%",     "来源": "Mask2Former", "类型": "数值",  "说明": "可见地面面积占比"},
  {"field": "sem_window_door_pct",      "中文名": "语义-门窗占比",     "单位": "%",     "来源": "Mask2Former", "类型": "数值",  "说明": "窗户+门在画面中的面积占比"},
  {"field": "sem_seating_pct",          "中文名": "语义-座椅占比",     "单位": "%",     "来源": "Mask2Former", "类型": "数值",  "说明": "椅子/沙发/凳子在画面中的面积占比"},
  {"field": "sem_work_surface_pct",     "中文名": "语义-工作台面占比", "单位": "%",     "来源": "Mask2Former", "类型": "数值",  "说明": "桌子/台面在画面中的面积占比"},
  {"field": "sem_storage_pct",          "中文名": "语义-储物占比",     "单位": "%",     "来源": "Mask2Former", "类型": "数值",  "说明": "柜子/书架/储物架在画面中的面积占比"},
  {"field": "sem_plant_deco_pct",       "中文名": "语义-植物装饰占比", "单位": "%",     "来源": "Mask2Former", "类型": "数值",  "说明": "绿植/花卉/装饰品在画面中的面积占比"},
  {"field": "sem_lighting_pct",         "中文名": "语义-照明占比",     "单位": "%",     "来源": "Mask2Former", "类型": "数值",  "说明": "灯具在画面中的面积占比"},

  {"field": "cv_brightness",            "中文名": "画面亮度",         "单位": "0-255",  "来源": "OpenCV",     "类型": "数值",  "说明": "V通道均值, 80昏暗, 130一般, 165明亮"},
  {"field": "cv_contrast",              "中文名": "画面对比度",       "单位": "0-255",  "来源": "OpenCV",     "类型": "数值",  "说明": "V通道标准差, 25均匀, 45正常, 70强对比"},
  {"field": "cv_color_temperature_K",   "中文名": "色温(CV计算)",     "单位": "K",      "来源": "OpenCV",     "类型": "整数",  "说明": "RGB比值推算, 3000K暖白, 6500K日光"},
  {"field": "cv_warmth_index",          "中文名": "冷暖指数",         "单位": "-",      "来源": "OpenCV",     "类型": "数值",  "说明": "暖色%-冷色%, -10冷调, 0中性, +10暖调"},
  {"field": "cv_saturation",            "中文名": "画面饱和度",       "单位": "0-255",  "来源": "OpenCV",     "类型": "数值",  "说明": "S通道均值, 30素雅, 50自然, 100鲜艳"},
  {"field": "cv_depth_cue",             "中文名": "纵深感",           "单位": "-",      "来源": "OpenCV",     "类型": "数值",  "说明": "近/远梯度比, <1扁平, 1中性, >1.5强纵深"}
]
